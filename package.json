{
  "name": "cloud-support-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:with-auth": "npm run build && npx wrangler pages dev dist --port 5173",
    "api:generate-client": "./generate-api-client.sh ../Quatt-cloud && npm run prettier:format",
    "api:clean-models": "node scripts/clean-api-models.js",
    "api:patch-models": "node scripts/patch-api-models.js",
    "api:generate-and-clean": "npm run api:generate-client && npm run api:clean-models && npm run api:patch-models",
    "build": "tsc && vite build",
    "build:staging": "tsc && vite build --mode staging",
    "build:development": "tsc && vite build --mode development",
    "prettier:format": "prettier --write .",
    "prettier:check": "prettier --check .",
    "lint": "eslint src --ext ts,tsx",
    "preview": "vite preview",
    "tsc:watch": "tsc -w",
    "prepare": "husky install",
    "check-types": "tsc --noEmit",
    "export-files": "./scripts/export_codebase_to_flat_file.sh",
    "show-file-sizes": "./scripts/show_file_sizes.sh",
    "review-diff": "node scripts/review_diff.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^3.9.0",
    "@tanstack/react-query": "^5.51.15",
    "@tanstack/react-query-devtools": "^5.51.15",
    "@uiw/react-json-view": "^2.0.0-alpha.39",
    "chart.js": "^4.5.1",
    "classnames": "^2.5.1",
    "date-fns": "^3.6.0",
    "dotenv": "^16.6.1",
    "firebase": "^9.23.0",
    "jose": "^6.1.0",
    "lodash-es": "^4.17.21",
    "qs": "^6.14.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.0",
    "react-datepicker": "^6.9.0",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.52.1",
    "react-qr-code": "^2.0.18",
    "react-query": "^3.39.3",
    "wouter": "^3.7.1",
    "yup": "^1.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251014.0",
    "@types/lodash-es": "^4.17.12",
    "@types/qs": "^6.14.0",
    "@types/react": "^18.3.3",
    "@types/react-datepicker": "^6.2.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^5.59.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^8.38.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.23",
    "husky": "^9.1.2",
    "lint-staged": "^15.5.2",
    "postcss-nesting": "^12.1.5",
    "prettier": "^3.6.2",
    "typescript": "^5.5.4",
    "vite": "^5.3.5"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "npm run lint"
    ],
    "src/**/*": [
      "npm run prettier:format"
    ]
  }
}
