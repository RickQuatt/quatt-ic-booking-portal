{
  "name": "cloud-support-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:with-auth": "npm run build && npx wrangler pages dev dist --port 5173",
    "openapi:gen:types": "npx openapi-typescript ../Quatt-cloud/src/spec/schemas/api-v1-bundled.yaml --output src/openapi-client/types/api/v1.ts",
    "build": "tsc && vite build",
    "build:staging": "tsc && vite build --mode staging",
    "build:development": "vite build --mode development",
    "prettier:format": "prettier --write .",
    "prettier:check": "prettier --check .",
    "lint": "eslint src --ext ts,tsx",
    "preview": "vite preview",
    "tsc:watch": "tsc -w",
    "prepare": "husky install",
    "check-types": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "npm run test:unit && npm run test:e2e",
    "playwright:install": "playwright install",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.51.15",
    "@tanstack/react-query-devtools": "^5.51.15",
    "@tanstack/react-table": "^8.21.3",
    "@uiw/react-json-view": "^2.0.0-alpha.39",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "driver.js": "^1.4.0",
    "firebase": "^9.23.0",
    "framer-motion": "^12.23.24",
    "jose": "^6.1.2",
    "lodash-es": "^4.17.21",
    "lucide-react": "^0.554.0",
    "next-themes": "^0.4.6",
    "openapi-fetch": "^0.15.0",
    "openapi-react-query": "^0.5.1",
    "qs": "^6.14.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.0",
    "react-confetti": "^6.4.0",
    "react-datepicker": "^6.9.0",
    "react-day-picker": "^9.13.0",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.66.1",
    "react-qr-code": "^2.0.18",
    "react-query": "^3.39.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "wouter": "^3.7.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@cloudflare/workers-types": "^4.20251014.0",
    "@playwright/test": "^1.56.1",
    "@storybook/addon-a11y": "^10.1.0",
    "@storybook/addon-docs": "^10.1.0",
    "@storybook/addon-onboarding": "^10.1.0",
    "@storybook/addon-vitest": "^10.1.0",
    "@storybook/react-vite": "^10.1.0",
    "@tailwindcss/postcss": "^4.1.17",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash-es": "^4.17.12",
    "@types/qs": "^6.14.0",
    "@types/react": "^18.3.3",
    "@types/react-datepicker": "^6.2.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^5.59.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/browser-playwright": "4.0.10",
    "@vitest/coverage-v8": "^4.0.10",
    "@vitest/ui": "^4.0.10",
    "autoprefixer": "^10.4.22",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.23",
    "eslint-plugin-storybook": "^0.11.1",
    "husky": "^9.1.2",
    "jsdom": "^27.2.0",
    "lint-staged": "^15.5.2",
    "msw": "^2.12.2",
    "playwright": "^1.56.1",
    "postcss": "^8.5.6",
    "postcss-nesting": "^12.1.5",
    "prettier": "^3.6.2",
    "storybook": "^10.1.0",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.5.4",
    "vite": "^5.3.5",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^4.0.10"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "npm run lint"
    ],
    "src/**/*": [
      "npm run prettier:format"
    ]
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
